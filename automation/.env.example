PORT=5000
CORS_ORIGIN=http://localhost:3000
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=your_github_username_or_org
GIT_AUTHOR_NAME=MVP Bot
GIT_AUTHOR_EMAIL=mvp-bot@example.com

# VPS Deploy (dùng thay cho Vercel + Render khi VPS_HOST được set)
# Yêu cầu trên VPS: nginx, nodejs, npm, pm2 đã cài sẵn
# Yêu cầu sudo NOPASSWD cho nginx: username ALL=(ALL) NOPASSWD: /bin/mv, /usr/sbin/nginx, /usr/bin/tee
VPS_HOST=
VPS_USER=
VPS_SSH_KEY_PATH=~/.ssh/id_rsa   # path tới private key, bỏ trống nếu dùng password
VPS_SSH_PASSWORD=                 # dùng password thay cho key (không khuyến khích)
VPS_FRONTEND_DIR=/var/www/sites   # thư mục chứa dist của từng site
VPS_BACKEND_DIR=/var/apps/sites   # thư mục chứa server của từng site
VPS_DOMAIN=                       # vd: yourdomain.com → site sẽ ở {name}.yourdomain.com
VPS_BACKEND_BASE_PORT=4000        # port backend bắt đầu từ, mỗi site dùng port riêng 4000–4999

# Capture image storage
# Leave CLOUD_IMAGE_PROVIDER empty to keep local files only.
# Supported values: cloudinary, imagekit
CLOUD_IMAGE_PROVIDER=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=captures

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_FOLDER=/captures
