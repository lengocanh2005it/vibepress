PORT=5000
CORS_ORIGIN=http://localhost:3000
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=your_github_username_or_org
GIT_AUTHOR_NAME=MVP Bot
GIT_AUTHOR_EMAIL=mvp-bot@example.com

# Capture image storage
# Leave CLOUD_IMAGE_PROVIDER empty to keep local files only.
# Supported values: cloudinary, imagekit
CLOUD_IMAGE_PROVIDER=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=captures

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_FOLDER=/captures
